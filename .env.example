# Скопируйте в .env и заполните значения: cp .env.example .env

# Anthropic API ключ — получить: https://console.anthropic.com
# Без ключа демо всё равно проходит на fallback-текстах (оффлайн-режим).
ANTHROPIC_API_KEY=

# Модель LLM (необязательно — дефолт claude-haiku-4-5)
ANTHROPIC_MODEL=claude-haiku-4-5
